{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Spotify Taskbar Widget",
    "version":  "0.3.0",
    "identifier":  "com.madal.spotify-taskbar-widget",
    "build":  {
                  "frontendDist":  "../src"
              },
    "app":  {
                "withGlobalTauri":  true,
                "windows":  [
                                {
                                    "title":  "Spotify Taskbar Widget",
                                    "width":  400,
                                    "height":  35,
                                    "decorations":  false,
                                    "transparent":  true,
                                    "alwaysOnTop":  true,
                                    "resizable":  false,
                                    "visible":  true,
                                    "skipTaskbar":  false
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ]
               }
}
